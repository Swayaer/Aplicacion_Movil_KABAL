{
  "expo": {
    "name": "Kabal",
    "slug": "Kabal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stockly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.sway502gt.stockly"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kabal necesita acceso a la cámara para escanear los productos de tu inventario."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4086e54a-8143-45aa-9346-144c4db4fd65"
      }
    },
    "owner": "sway502gt",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4086e54a-8143-45aa-9346-144c4db4fd65"
    }
  }
}
